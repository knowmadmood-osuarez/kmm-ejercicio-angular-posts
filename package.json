{
  "name": "@kmm-ejercicio-angular-posts/source",
  "version": "0.0.0",
  "license": "MIT",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=24.14.1",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "start": "nx serve posts-app",
    "start:api": "nx serve api",
    "dev": "nx run-many --targets=serve --projects=posts-app,api",
    "dev:ssr": "concurrently --kill-others --names api,app \"pnpm start:api\" \"nx serve posts-app\"",
    "build": "nx build posts-app",
    "build:prod": "nx build posts-app --configuration=production",
    "serve:ssr": "node dist/posts-app/server/server.mjs",
    "start:ssr": "pnpm build:prod && pnpm serve:ssr",
    "start:prod": "concurrently --kill-others --names api,ssr \"pnpm start:api\" \"pnpm serve:ssr\"",
    "lint": "nx run-many --target=lint --all",
    "test": "nx run-many --target=test --all",
    "test:watch": "nx test posts-app --watch",
    "test:libs:coverage": "nx run-many --target=test --exclude=posts-app --coverage",
    "test:coverage": "nx test posts-app && nx run-many --target=test --exclude=posts-app --coverage",
    "e2e": "nx e2e posts-app-e2e",
    "format": "prettier --write \"{apps,libs}/**/*.{ts,html,css,json}\"",
    "format:check": "prettier --check \"{apps,libs}/**/*.{ts,html,css,json}\"",
    "prepare": "husky"
  },
  "private": true,
  "dependencies": {
    "@angular/common": "~21.2.0",
    "@angular/compiler": "~21.2.0",
    "@angular/core": "~21.2.0",
    "@angular/forms": "~21.2.0",
    "@angular/platform-browser": "~21.2.0",
    "@angular/platform-server": "^21.2.8",
    "@angular/router": "~21.2.0",
    "@angular/ssr": "^21.2.7",
    "@jsverse/transloco": "^7.0.0",
    "express": "^5.2.1",
    "rxjs": "~7.8.0"
  },
  "devDependencies": {
    "@analogjs/vite-plugin-angular": "~2.1.2",
    "@analogjs/vitest-angular": "~2.1.2",
    "@angular-devkit/core": "~21.2.0",
    "@angular-devkit/schematics": "~21.2.0",
    "@angular/build": "~21.2.0",
    "@angular/cli": "~21.2.0",
    "@angular/compiler-cli": "~21.2.0",
    "@angular/language-service": "~21.2.0",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^9.8.0",
    "@juristr/nx-tailwind-sync": "^0.0.9",
    "@nx/angular": "22.6.4",
    "@nx/eslint": "22.6.4",
    "@nx/eslint-plugin": "22.6.4",
    "@nx/js": "22.6.4",
    "@nx/playwright": "^22.6.4",
    "@nx/vite": "22.6.4",
    "@nx/vitest": "22.6.4",
    "@nx/web": "22.6.4",
    "@nx/workspace": "22.6.4",
    "@oxc-project/runtime": "^0.115.0",
    "@playwright/test": "^1.59.1",
    "@schematics/angular": "~21.2.0",
    "@swc-node/register": "~1.11.1",
    "@swc/core": "~1.15.5",
    "@swc/helpers": "~0.5.18",
    "@tailwindcss/postcss": "^4.0.0",
    "@testing-library/angular": "^19.2.1",
    "@types/express": "^5.0.6",
    "@types/node": "20.19.9",
    "@typescript-eslint/utils": "^8.40.0",
    "@vitest/coverage-v8": "~4.1.0",
    "@vitest/ui": "~4.1.0",
    "angular-eslint": "^21.2.0",
    "concurrently": "^9.0.0",
    "eslint": "^9.8.0",
    "eslint-config-prettier": "^10.0.0",
    "husky": "^9.1.7",
    "jsdom": "^27.1.0",
    "json-server": "^1.0.0-beta.3",
    "lint-staged": "^16.4.0",
    "nx": "22.6.4",
    "prettier": "~3.6.2",
    "tailwindcss": "^4.0.0",
    "tslib": "^2.3.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.40.0",
    "vite": "^8.0.0",
    "vitest": "^4.0.8"
  },
  "nx": {
    "includedScripts": []
  },
  "lint-staged": {
    "*.{ts,html}": [
      "eslint --fix"
    ],
    "*.{ts,html,css,json}": [
      "prettier --write"
    ]
  }
}
